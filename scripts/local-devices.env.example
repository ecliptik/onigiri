# Device identity for scripts/deploy-phone.sh — copy to
# scripts/local-devices.env (gitignored) and fill in your devices.
#
#   cp scripts/local-devices.env.example scripts/local-devices.env
#
# DEVICE_NAME: your iPhone's name as it appears in Xcode.
# WATCH_BUILD_ID: the watch's hardware UDID (xcodebuild wants this).
# WATCH_INSTALL_ID: the watch's CoreDevice identifier (devicectl wants
#   this). Find both via: xcrun devicectl list devices
# Leave the watch variables empty to deploy the phone only.

DEVICE_NAME="My iPhone"
WATCH_BUILD_ID=""
WATCH_INSTALL_ID=""
